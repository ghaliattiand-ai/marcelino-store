# =========================================
# .gitignore موحّد لمشروع MARCELINO (root)
# يجمع قواعد: backend (Node) + Flutter app + admin-panel
# =========================================

# ===== Node (backend) =====
**/node_modules/
**/npm-debug.log*
**/yarn-error.log*

# ===== Secrets / Environment =====
.env
**/.env
.env.local
**/.env.local

# ===== Android signing secrets =====
**/android/key.properties
*.jks
*.keystore
**/android/app/upload-keystore.jks

# ===== Flutter / Dart =====
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
**/build/
# pubspec.lock على root الـ sameh/ لبر全文 تاني — نتجاهله
/pubspec.lock
/pubspec.yaml

# ===== IDE / Editor =====
*.iml
*.ipr
*.iws
.idea/
.vscode/
*.code-workspace

# ===== OS / Misc =====
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/
Thumbs.db

# ===== Backend uploads (دائم على Cloudinary، لا نلتزم بالـ repo) =====
# نتجاهل محتويات uploads/ لكن نحتفظ بالمجلد عبر .gitkeep
**/backend/uploads/*
!**/backend/uploads/.gitkeep
